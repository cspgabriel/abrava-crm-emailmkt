# ============================================================================
# Root Environment Variables Example
# ============================================================================
# Este arquivo é um template. Não editar aqui.
# VS arquivo específico em abravacom-main/crm/.env.example
#
# Para desenvolvimento local:
#   Copie abravacom-main/crm/.env.example para abravacom-main/crm/.env
#
# Para produção (Vercel):
#   Configure as variáveis no dashboard do Vercel
# ============================================================================

# WhatsApp API (Vercel)
VITE_WPP_API_KEY=your-secret-key
VITE_WHATSAPP_API_URL=https://your-ngrok-or-tunnel-url

# Firebase (Vercel)
VITE_FIREBASE_API_KEY=your-firebase-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Gemini AI (Opcional)
VITE_GEMINI_API_KEY=your-gemini-key
