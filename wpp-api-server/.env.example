# Example env for wpp-api-server
PORT=8787
# Shared secret for CRM -> API calls (set this in Vercel and in your CRM .env)
X_API_KEY=change-me-to-a-strong-secret
# Restrict CORS to your CRM domain
ALLOWED_ORIGIN=https://abravacom.com.br
# Optional: comma-separated list of trusted origins accepted for browser fallback on POST /send
ALLOWED_ORIGINS=https://abravacom.com.br,http://localhost:3001

# ========== PUPPETEER / CHROME CONFIGURATION ==========
# Set to 'true' for headless mode (no visible window)
# Set to 'false' to see the browser window (useful for debugging)
WPP_HEADLESS=true

# ========== FIX FOR "ERRO DE PERFIL" / PROFILE ERROR ==========
# If you get "Ocorreu um erro de perfil":
# 1. Execute: npm run session:clear
# 2. Execute: npm run dev
# 3. If error persists, run: powershell -ExecutionPolicy Bypass .\clean-profile-error.ps1
# 4. As a last resort, restart your computer and try again
# =========================================================

# ========== SESSION PERSISTENCE (IMPORTANT!) ==========
# The WhatsApp session is AUTOMATICALLY SAVED after first QR scan
# File: .wwebjs_auth/session-abravacon-wpp/
# 
# Session will be RESTORED on next server restart WITHOUT needing QR again!
#
# To manually clear session and force QR rescan:
#   npm run session:clear
#
# To check session status:
#   npm run session:status
#
# To backup current session:
#   npm run session:backup
#
# To restore from backup:
#   npm run session:restore
# =====================================================
