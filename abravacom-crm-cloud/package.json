{
  "name": "abravacom-crm-cloud",
  "version": "1.0.0",
  "description": "Acesso desktop para o CRM Nuvem Abravacom",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "author": "Abravacom",
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.abravacom.crm",
    "productName": "CRM Abravacom",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico",
      "sign": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "CRM Abravacom"
    }
  }
}
