# ============================================================================
# 🌐 WhatsApp API Configuration
# ============================================================================

# Para DESENVOLVIMENTO LOCAL (localhost:3001):
# O app usa automaticamente http://localhost:8787
# Copie este arquivo para .env e deixe como está

# Para PRODUÇÃO (Vercel):
# Configure a URL pública do seu servidor WPP API (NGROK, Tunnel, etc.)
# Exemplo: https://abc123.ngrok.io

VITE_WHATSAPP_API_URL=https://wpp-api.abravacom.com.br
VITE_WPP_API_KEY=change-me-to-a-strong-secret

# ============================================================================
# 🔥 Firebase Configuration
# ============================================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================================
# 🤖 Gemini AI (Opcional)
# ============================================================================

VITE_GEMINI_API_KEY=

# ============================================================================
# 📝 INSTRUÇÕES
# ============================================================================

# 1. DESENVOLVIMENTO LOCAL
#    a) Copie este arquivo para .env na mesma pasta
#    b) Preencha as variáveis Firebase e Gemini
#    c) O WPP API URL será automático (localhost:8787)
#    d) Execute: npm run dev
#
# 2. PARA VERCEL
#    a) Configure as variáveis no Vercel Dashboard
#    b) Certifique-se de que o servidor WPP API está exposto
#       (use NGROK, Cloudflare Tunnel, ou similar)
#    c) Coloque a URL pública em VITE_WHATSAPP_API_URL
#    d) Push para GitHub - Vercel fará deploy automático
#
# 3. IMPORTANTE
#    - NÃO commit o arquivo .env (está no .gitignore)
#    - Sempre use este .env.example como template
#    - Valores sensíveis devem estar em variáveis de ambiente

