{
  "buildCommand": "cd crm && npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "crm/dist",
  "env": {
    "VITE_WPP_API_KEY": "@wpp_api_key",
    "VITE_WHATSAPP_API_URL": "@whatsapp_api_url"
  },
  "rewrites": [
    {
      "source": "/crm/(.*)",
      "destination": "/crm/index.html"
    }
  ]
}
